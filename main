=======
# Conway's Game of Life implementation in Python using Tkinter
# Written by Kenneth Wu, Mars Sun, and Bernard Kim
# July 11, 2026

import tkinter as tk
from random import random

CELL=12
ROWS,COLS=50,70

class Life:
    def __init__(self,root):
        self.root=root
        self.running=False
        self.grid=[[0]*COLS for _ in range(ROWS)]
        self.cv=tk.Canvas(root,width=COLS*CELL,height=ROWS*CELL,bg="white")
        self.cv.pack()
        bar=tk.Frame(root); bar.pack()
        tk.Button(bar,text="Play/Pause",command=self.toggle).pack(side="left")
        tk.Button(bar,text="Step",command=self.step).pack(side="left")
        tk.Button(bar,text="Random",command=self.rand).pack(side="left")
        tk.Button(bar,text="Clear",command=self.clear).pack(side="left")
        self.cv.bind("<Button-1>",self.click)
        self.draw()

    def click(self,e):
        c=e.x//CELL; r=e.y//CELL
        if 0<=r<ROWS and 0<=c<COLS:
            self.grid[r][c]^=1
            self.draw()

    def draw(self):
        self.cv.delete("all")
        for r in range(ROWS):
            for c in range(COLS):
                x,y=c*CELL,r*CELL
                fill="black" if self.grid[r][c] else "white"
                self.cv.create_rectangle(x,y,x+CELL,y+CELL,fill=fill,outline="#ccc")

    def neighbors(self,r,c):
        s=0
        for dr in(-1,0,1):
            for dc in(-1,0,1):
                if dr==dc==0: continue
                rr,cc=r+dr,c+dc
                if 0<=rr<ROWS and 0<=cc<COLS:
                    s+=self.grid[rr][cc]
        return s

    def step(self):
        new=[[0]*COLS for _ in range(ROWS)]
        for r in range(ROWS):
            for c in range(COLS):
                n=self.neighbors(r,c)
                new[r][c]=1 if (self.grid[r][c] and n in (2,3)) or (not self.grid[r][c] and n==3) else 0
        self.grid=new
        self.draw()

    def loop(self):
        if self.running:
            self.step()
        self.root.after(100,self.loop)

    def toggle(self):
        self.running=not self.running

    def rand(self):
        self.grid=[[1 if random()<0.25 else 0 for _ in range(COLS)] for _ in range(ROWS)]
        self.draw()

    def clear(self):
        self.grid=[[0]*COLS for _ in range(ROWS)]
        self.draw()

root=tk.Tk()
root.title("Conway's Game of Life")
app=Life(root)
app.loop()
root.mainloop()
